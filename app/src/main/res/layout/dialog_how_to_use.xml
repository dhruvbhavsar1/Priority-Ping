<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How to Use PriorityPing"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Add Priority Contacts"
            android:textColor="#A78BFA"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Click the '+' button to add contacts from WhatsApp, Instagram, or Snapchat. Use the EXACT name as it appears in your notifications."
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Set Priority Levels"
            android:textColor="#A78BFA"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• HIGH: Vibrate + Notification Sound (Plays even in Silent mode if Alarm volume is up).\n• MEDIUM: Custom Vibration only.\n• NORMAL: Default system behavior."
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. Silent Mode Tip"
            android:textColor="#FBBF24"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="For sounds to play while your phone is in Silent/Vibrate mode, please ensure your 'Alarm Volume' is turned up in your phone settings."
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4. Troubleshooting"
            android:textColor="#A78BFA"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="If notifications aren't working, make sure 'Notification Access' is granted in Settings and the app is not being optimized by battery saver."
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDismiss"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Got it!"
            android:textColor="#FFFFFF"
            app:backgroundTint="#5B4FCF"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>